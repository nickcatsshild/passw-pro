<main class="container-xxl">
    <div class="align-items-center p-3 mb-3 bg-secondary rounded shadow">
        <div>
            <h6 class="text-white mb-3">Backup & Restore</h6>
            <div class="small text-white mb-2">
                Create a complete backup of all data: database, config, attachments, sends, and RSA keys.
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Create Backup</h5>
                            <p class="card-text small">Creates a .tar.gz archive with the full vault data.</p>
                            <button type="button" class="btn btn-primary w-100" id="createBackup">
                                Create Backup Now
                            </button>
                            <div id="backupProgress" class="mt-2 d-none">
                                <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                Creating backup...
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Restore Backup</h5>
                            <p class="card-text small">Upload a .tar.gz backup file to restore all data.</p>
                            <form id="restoreForm">
                                <div class="mb-2">
                                    <input class="form-control" type="file" id="restoreFile" accept=".tar.gz,.gz">
                                </div>
                                <button type="submit" class="btn btn-warning w-100" id="restoreBtn">
                                    Restore from Backup
                                </button>
                            </form>
                            <div id="restoreProgress" class="mt-2 d-none">
                                <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                Restoring backup...
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-warning mt-2">
                <strong>Warning:</strong> Restoring a backup will overwrite all current data including the database,
                attachments, and configuration. The server should be restarted after a restore for all changes to take effect.
            </div>

            {{#if page_data.backups.length}}
            <div class="mt-3">
                <h6 class="text-white mb-2">Existing Backups</h6>
                <div class="table-responsive">
                    <table class="table table-dark table-striped table-sm">
                        <thead>
                            <tr>
                                <th>Filename</th>
                                <th>Size</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each page_data.backups}}
                            <tr>
                                <td class="text-break">{{name}}</td>
                                <td>{{size_formatted}}</td>
                                <td>{{modified}}</td>
                                <td>
                                    <a href="{{../urlpath}}/admin/backup/download/{{name}}" class="btn btn-sm btn-success me-1">
                                        Download
                                    </a>
                                    <button class="btn btn-sm btn-danger delete-backup"
                                        data-filename="{{name}}">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
            {{/if}}

        </div>
    </div>
</main>
<script src="{{urlpath}}/vw_static/admin_backup.js"></script>
